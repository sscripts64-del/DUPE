local lp = Players.LocalPlayer
local gui = lp:WaitForChild("PlayerGui")
local TradeItemRemote = ReplicatedStorage:FindFirstChild("TradeItem")
local ItemData = ReplicatedStorage:FindFirstChild("Item")

local effectItemsCache = nil

local function GetEffectItems()
    if not ItemData then return {} end
    if not effectItemsCache then
        effectItemsCache = {}
        local success, data = pcall(require, ItemData)
        if success then
            for itemName, itemInfo in pairs(data) do
                if itemInfo.ItemType == "Effect" then
                    effectItemsCache[itemName] = true
                end
            end
        end
    end
    return effectItemsCache
end

local function GetTradingPartner()
    local mainFrame = gui:FindFirstChild("Main")
    if not mainFrame then return nil end
    local tradingFrame = mainFrame:FindFirstChild("MainTradingFrame")
    if not tradingFrame then return nil end
    
    local text = tradingFrame.Slots.TradingPlayerName.Text
    local username = text:match("@(.+)%)")
    
    if username then 
        return Players:FindFirstChild(username) 
    end
    return nil
end

local function GetAllMyWeapons()
    local weapons = {}
    local effectItems = GetEffectItems()
    
    local skinsFolder = lp:FindFirstChild("SkinsFolder")
    if not skinsFolder then return weapons end

    for _, item in ipairs(skinsFolder:GetChildren()) do
        if item:IsA("StringValue")
            and item.Name ~= "DefaultGun"
            and item.Name ~= "DefaultKnife"
            and not effectItems[item.Name] then

            local count = item:FindFirstChild("Count") and item.Count.Value or 1

            for i = 1, count do
                table.insert(weapons, item.Name)
            end
        end
    end

    return weapons
end

local function AddAllWeapons(partner)
    if not TradeItemRemote then return end
    local weapons = GetAllMyWeapons()
    
    for _, weaponName in ipairs(weapons) do
        task.spawn(function()
            pcall(function()
                TradeItemRemote:InvokeServer("ADD_TO_TRADE", partner, weaponName, {})
            end)
        end)
    end
end

